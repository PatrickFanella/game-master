# Database
GM_DB_URL=postgres://game_master:game_master@localhost:5432/game_master?sslmode=disable

# LLM Provider (ollama or claude)
GM_LLM_PROVIDER=ollama

# Ollama (main LLM - desktop GPU)
GM_LLM_OLLAMA_ENDPOINT=http://10.0.0.10:11434
GM_LLM_OLLAMA_MODEL=qwen3:14b
GM_LLM_OLLAMA_TIMEOUTSECONDS=180

# Ollama (embedding - local server)
GM_LLM_OLLAMA_EMBEDDINGENDPOINT=http://ollama:11434
GM_LLM_OLLAMA_EMBEDDINGMODEL=nomic-embed-text

# Claude (required if GM_LLM_PROVIDER=claude)
# API key precedence (highest to lowest): GM_LLM_CLAUDE_APIKEY > GM_CLAUDE_API_KEY > ANTHROPIC_API_KEY
# GM_LLM_CLAUDE_APIKEY=sk-ant-...
# GM_CLAUDE_API_KEY=sk-ant-...
# ANTHROPIC_API_KEY=sk-ant-...
# GM_LLM_CLAUDE_MODEL=claude-sonnet-4-6

# Server
GM_SERVER_PORT=8080
